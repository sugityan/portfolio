{
  "root": true,
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": [
    "eslint:recommended",
    "@typescript-eslint/recommended"
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "project": "./tsconfig.json"
  },
  "plugins": [
    "@typescript-eslint"
  ],
  "rules": {
    // 通常の no-unused-vars はオフにする（代わりに TS 版を使う）
    "no-unused-vars": "off",
    // 未使用変数をエラーに
    "@typescript-eslint/no-unused-vars": "error"
  }
}